# ─────────────────────────────────────────────────────────────────────────────
# Retell SIP Middleware — environment configuration
# Copy to `.env` and fill in. NEVER commit the real .env (see .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=production
PORT=3000
LOG_LEVEL=info
# Optional: surfaced by /health. Set in CI to the git SHA.
APP_VERSION=dev

# Public HTTPS base URL of THIS webhook service (what Jambonz calls).
# e.g. https://caller.yourdomain.com
PUBLIC_BASE_URL=

# ── Retell ───────────────────────────────────────────────────────────────────
RETELL_API_KEY=
RETELL_AGENT_ID=
RETELL_API_BASE_URL=https://api.retellai.com
# Host part of the dynamic SIP URI dialed after a call is registered.
RETELL_SIP_DOMAIN=sip.retellai.com
# How long (s) we treat a freshly registered Retell SIP URI as dialable.
RETELL_SIP_URI_TTL_SECONDS=60

# ── URL Networks SIP trunk — REGISTRATION TRUNK (we register TO them) ─────────
# Mode confirmed: our SIP server logs into URL Networks with these creds and
# inbound calls return over the registered connection. Reuse the EXACT values
# 3CX used. If registrar == proxy == realm (common), set all three the same.
SIP_PROVIDER_NAME=URL_NETWORKS
SIP_USERNAME=              # trunk username
SIP_PASSWORD=             # trunk password
SIP_REGISTRAR=           # registrar host, where REGISTER is sent (e.g. sip.urlnetworks.com)
SIP_PROXY=               # outbound proxy/gateway for INVITEs (often same as registrar)
SIP_REALM=               # digest auth realm / SIP domain (often same as registrar)
SIP_TRANSPORT=udp        # udp | tcp | tls — match what URL Networks accepts

# ── Network / media ──────────────────────────────────────────────────────────
PUBLIC_IP=
SIP_PORT=5060
RTP_PORT_START=40000
RTP_PORT_END=60000

# ── Error fallback ───────────────────────────────────────────────────────────
# hangup | play_message | forward_to_backup_number
ERROR_FALLBACK_MODE=hangup
BACKUP_NUMBER=
ERROR_FALLBACK_MESSAGE=Sorry, we are unable to connect your call right now. Please try again later.

# ── Webhook auth (optional) ──────────────────────────────────────────────────
# Shared secret enforced via HTTP Basic auth on Jambonz -> middleware webhooks.
JAMBONZ_WEBHOOK_SECRET=
